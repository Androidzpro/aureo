# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aureo?schema=public

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Server Configuration
PORT=3001
NODE_ENV=development

# Client Configuration
CLIENT_URL=http://localhost:5173

# Supabase (Optional - if using Supabase instead of local PostgreSQL)
SUPABASE_URL=
SUPABASE_KEY=

# Email Configuration (Optional - for password reset, notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Application Configuration
APP_NAME=Aureo
APP_URL=http://localhost:5173
