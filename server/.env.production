# Production Environment Variables for Render
# These will be set in Render dashboard, not in .env file

NODE_ENV=production
PORT=3001

# Database - Set to your Supabase connection string
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@[pooler-host]:6543/postgres?sslmode=require

# JWT - Generate a secure secret
JWT_SECRET=change-this-to-a-random-secure-string
JWT_EXPIRES_IN=7d

# Frontend URL - Update after deploying to Vercel
CLIENT_URL=https://aureo.vercel.app
